{
    "layer": "top",
    "position": "top",
    "height": 32,
    "spacing": 4,
    "modules-left": [
        "sway/workspaces",
        "sway/mode",
        "sway/scratchpad"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "custom/aios-status",
        "custom/aios-model",
        "cpu",
        "memory",
        "temperature",
        "disk",
        "network",
        "pulseaudio",
        "battery",
        "tray",
        "custom/voice"
    ],

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
            "1:term": "",
            "2:web": "蟀埞",
            "3:code": "蟀",
            "4:docker": "蟀〃",
            "5:k8s": "蟊兙",
            "6:logs": "蟀嫨",
            "7:ai": "蟀毄",
            "8:media": "",
            "9:misc": "",
            "10:float": "蟊梹",
            "urgent": "",
            "focused": "",
            "default": ""
        }
    },

    "clock": {
        "timezone": "Europe/Bratislava",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%d.%m %H:%M}",
        "format-alt": "{:%A, %d %B %Y   %H:%M:%S}"
    },

    "cpu": {
        "format": "蟀粻 {usage}%",
        "tooltip": false,
        "interval": 2,
        "on-click": "alacritty -e htop"
    },

    "memory": {
        "format": "蟀崨 {used:.1f}G",
        "interval": 5
    },

    "temperature": {
        "critical-threshold": 80,
        "format": "{icon} {temperatureC}掳C",
        "format-icons": ["", "", ""]
    },

    "disk": {
        "format": "蟀媻 {percentage_used}%",
        "path": "/",
        "interval": 30,
        "tooltip-format": "{path}: {used} / {total}"
    },

    "network": {
        "format-wifi": "蟀え {signalStrength}%",
        "format-ethernet": "蟀垁 {ipaddr}",
        "format-disconnected": "蟀き",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}\nSpeed: 鈫憑bandwidthUpBytes} 鈫搟bandwidthDownBytes}",
        "on-click": "alacritty -e nmtui"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "蟀潫",
        "format-icons": {
            "default": ["蟀暱", "蟀杸", "蟀暰"]
        },
        "on-click": "pavucontrol"
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "蟀倓 {capacity}%",
        "format-plugged": "蟀倓 {capacity}%",
        "format-icons": ["蟀伜", "蟀伝", "蟀伡", "蟀伣", "蟀伨", "蟀伩", "蟀個", "蟀倎", "蟀倐", "蟀伖"]
    },

    "tray": {
        "spacing": 8
    },

    "custom/aios-status": {
        "exec": "aios-waybar-status",
        "interval": 10,
        "format": "蟀毄 {}",
        "tooltip": true,
        "on-click": "aios-panel toggle"
    },

    "custom/aios-model": {
        "exec": "aios-waybar-model",
        "interval": 30,
        "format": "{}",
        "tooltip": true
    },

    "custom/voice": {
        "exec": "aios-waybar-voice",
        "interval": 2,
        "format": "{}",
        "on-click": "aios-voice-trigger",
        "tooltip": true
    }
}
