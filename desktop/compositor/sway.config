# AIOS Sway Wayland compositor configuration
# Place at: ~/.config/sway/config

# ─── Basics ──────────────────────────────────────────────────────────────────
set $mod Mod4
set $term alacritty
set $menu rofi -show drun -theme aios
set $locker swaylock -f -c 000000

font pango:JetBrains Mono Nerd Font 11

# Screen gaps
gaps inner 8
gaps outer 4
smart_gaps on

# Window borders
default_border pixel 2
default_floating_border pixel 2

# Focus follows mouse
focus_follows_mouse yes

# ─── Colors (AIOS dark theme) ─────────────────────────────────────────────────
# class                 border    bg        text      indicator  child_border
client.focused          #00bcd4   #006064   #ffffff   #00e5ff    #00bcd4
client.focused_inactive #263238   #1c2026   #90a4ae   #263238    #263238
client.unfocused        #1c2026   #121212   #546e7a   #1c2026    #1c2026
client.urgent           #f44336   #b71c1c   #ffffff   #f44336    #f44336

# ─── Output ───────────────────────────────────────────────────────────────────
output * bg /usr/share/aios/wallpaper.png fill
# output eDP-1 scale 1.5  # uncomment for HiDPI

# ─── Input ────────────────────────────────────────────────────────────────────
input "type:keyboard" {
    xkb_layout sk,us
    xkb_options grp:alt_shift_toggle,caps:escape
    repeat_delay 300
    repeat_rate 50
}
input "type:touchpad" {
    tap enabled
    natural_scroll enabled
    dwt enabled
}

# ─── Workspaces ───────────────────────────────────────────────────────────────
set $ws1  "1:term"
set $ws2  "2:web"
set $ws3  "3:code"
set $ws4  "4:docker"
set $ws5  "5:k8s"
set $ws6  "6:logs"
set $ws7  "7:ai"
set $ws8  "8:media"
set $ws9  "9:misc"
set $ws10 "10:float"

# ─── Window rules ─────────────────────────────────────────────────────────────
assign [app_id="firefox"]          $ws2
assign [app_id="code-url-handler"] $ws3
assign [app_id="nvim"]             $ws3
assign [title="AIOS Panel"]        $ws7
assign [title="Portainer"]         $ws4
assign [title="k9s"]               $ws5

for_window [app_id="pavucontrol"]  floating enable
for_window [title="Picture-in-Picture"] floating enable, sticky enable

# AIOS Panel — always visible on right side
for_window [app_id="aios-panel"] {
    floating enable
    sticky enable
    border pixel 0
}

# ─── Keybindings ─────────────────────────────────────────────────────────────

# Terminal
bindsym $mod+Return exec $term

# AIOS AI panel toggle
bindsym $mod+a exec aios-panel toggle

# AIOS voice command
bindsym $mod+v exec aios-voice-trigger

# AIOS chat in terminal
bindsym $mod+shift+a exec $term --title "AIOS Shell" -e aios shell

# Run agent with clipboard as task
bindsym $mod+shift+v exec aios agent "$(wl-paste)"

# App launcher
bindsym $mod+d exec $menu

# File manager
bindsym $mod+e exec $term -e ranger

# Browser
bindsym $mod+shift+b exec firefox

# Docker TUI
bindsym $mod+shift+d exec $term -e lazydocker

# K8s TUI
bindsym $mod+shift+k exec $term -e k9s

# Htop
bindsym $mod+shift+h exec $term -e htop

# Lock screen
bindsym $mod+l exec $locker

# Screenshot
bindsym Print exec grim -g "$(slurp)" - | wl-copy

# Kill window
bindsym $mod+q kill

# Reload config
bindsym $mod+shift+r reload

# Exit
bindsym $mod+shift+e exec swaynag -t warning -m 'Exit AIOS?' -b 'Yes' 'swaymsg exit'

# Resize
bindsym $mod+r mode "resize"
mode "resize" {
    bindsym Left  resize shrink width  10px
    bindsym Down  resize grow   height 10px
    bindsym Up    resize shrink height 10px
    bindsym Right resize grow   width  10px
    bindsym Escape mode "default"
    bindsym Return mode "default"
}

# Move/focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

bindsym $mod+shift+h move left
bindsym $mod+shift+j move down
bindsym $mod+shift+k move up
bindsym $mod+shift+l move right

bindsym $mod+f fullscreen toggle
bindsym $mod+shift+space floating toggle
bindsym $mod+space layout toggle split

# Workspace switching
bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5
bindsym $mod+6 workspace $ws6
bindsym $mod+7 workspace $ws7
bindsym $mod+8 workspace $ws8
bindsym $mod+9 workspace $ws9
bindsym $mod+0 workspace $ws10

bindsym $mod+shift+1 move container to workspace $ws1
bindsym $mod+shift+2 move container to workspace $ws2
bindsym $mod+shift+3 move container to workspace $ws3
bindsym $mod+shift+4 move container to workspace $ws4
bindsym $mod+shift+5 move container to workspace $ws5

# Audio
bindsym XF86AudioRaiseVolume  exec pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym XF86AudioLowerVolume  exec pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym XF86AudioMute         exec pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym XF86AudioMicMute      exec pactl set-source-mute @DEFAULT_SOURCE@ toggle

# Brightness
bindsym XF86MonBrightnessUp   exec brightnessctl set +10%
bindsym XF86MonBrightnessDown exec brightnessctl set 10%-

# ─── Status bar (Waybar) ──────────────────────────────────────────────────────
bar {
    swaybar_command waybar
}

# ─── Autostart ────────────────────────────────────────────────────────────────
exec_always --no-startup-id {
    # AIOS daemon
    systemctl --user start aiosd
    # Notification daemon
    mako
    # Clipboard manager
    wl-paste --watch cliphist store
    # Network manager applet
    nm-applet --indicator
    # Pipewire audio
    pipewire &
    wireplumber &
}
